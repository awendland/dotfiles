# Programs Reference
#
# NOTE: Actual package installation is managed by laptop-mbp ansible playbook.
# This file is a reference for programs used by these dotfiles configs.

#################
#     Unix      #
#################
fish          # Friendly shell w/ good defaults
neovim        # Improved vim (config in _vimrc)
tree          # Prints out directory structure
ripgrep       # Fast grep (rg) - replaced ag
wget          # Easy Internet download program
trash         # rm but moves to trash
fzf           # Fuzzy file finder
git-delta     # Better diff UI for git - replaced diff-so-fancy
starship      # Cross-shell prompt

#################
#  Version Mgmt #
#################
mise          # Dev tool version manager (node, go, terraform) - replaced asdf/nvm
uv            # Python package/tool manager - replaced pyenv/pip

#################
#     macOS     #
#################
brew          # macOS package manager
